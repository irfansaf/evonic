{
  "id": "auto_improver",
  "name": "Auto Improver",
  "version": "1.0.0",
  "description": "Auto-analyze agent conversations, identify issues, and suggest improvements and optimizations",
  "author": "Evonic",
  "enabled": true,
  "nav_label": "Auto Improver",
  "nav_route": "/auto_improver",
  "nav_icon": "🔍",
  "routes": [
    {
      "path": "/api/auto_improver",
      "methods": [
        "GET",
        "POST"
      ],
      "handler": "api"
    }
  ],
  "events": [
    "turn_complete"
  ],
  "variables": [
    {
      "name": "AUTO_ANALYSIS_ENABLED",
      "label": "Auto Analysis Enabled",
      "type": "boolean",
      "default": false
    },
    {
      "name": "ANALYSIS_DEPTH",
      "label": "Analysis Depth",
      "type": "string",
      "default": "medium"
    },
    {
      "name": "MIN_TURN_THRESHOLD",
      "label": "Min Turns Before Analysis",
      "type": "number",
      "default": 3
    },
    {
      "name": "TARGET_AGENT_ID",
      "label": "Target Agent ID (optional)",
      "type": "string",
      "default": ""
    }
  ]
}
